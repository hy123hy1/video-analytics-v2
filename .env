# Video Analytics System 环境变量配置示例
# 复制此文件为 .env 并根据需要修改

# ==================== 日志配置 ====================
VA_SERVER_LOG_LEVEL=INFO
VA_SERVER_LOG_FILE=logs/video_analytics.log

# ==================== 服务器配置 ====================
VA_SERVER_HOST=0.0.0.0
VA_SERVER_PORT=5005
VA_SERVER_RTSP_PUSH_HOST=192.168.1.61

# ==================== 模型配置 ====================
# 模型后端: ultralytics / tensorrt / onnx / torch
VA_MODEL_BACKEND=ultralytics
VA_MODEL_PERSON_MODEL_PATH=models/yolov8n.pt
VA_MODEL_HELMET_MODEL_PATH=models/safehat.pt
VA_MODEL_SMOKEFIRE_MODEL_PATH=video_analytics/models/smokefire.pt
VA_MODEL_CONFIDENCE=0.4
VA_MODEL_IOU=0.45
VA_MODEL_DEVICE_ID=0
VA_MODEL_FP16=false

# ==================== 检测配置 ====================
VA_DETECTION_INTRUSION_MIN_FRAMES=25
VA_DETECTION_INTRUSION_COOLDOWN=60.0
VA_DETECTION_HELMET_MIN_FRAMES=25
VA_DETECTION_HELMET_COOLDOWN=60.0
VA_DETECTION_OVERCROWD_MAX_PEOPLE=15
VA_DETECTION_OVERCROWD_DURATION=2.0

# 烟火检测配置
VA_DETECTION_FIRE_MIN_FRAMES=25
VA_DETECTION_FIRE_COOLDOWN=60.0
VA_DETECTION_FIRE_CONFIDENCE=0.4

# ==================== 存储配置 ====================
# 存储类型: minio / local
VA_STORAGE_TYPE=minio
VA_STORAGE_ENDPOINT=192.168.1.61:9000
VA_STORAGE_ACCESS_KEY=admin
VA_STORAGE_SECRET_KEY=12345678
VA_STORAGE_BUCKET_NAME=yolo
VA_STORAGE_SECURE=false

# ==================== 报警配置 ====================
# 报警类型: http / async / console
VA_ALARM_TYPE=http
# 多个端点用逗号分隔
VA_ALARM_ENDPOINTS=http://localhost:8080/api/alarm
VA_ALARM_ENDPOINTS_INTRUSION=http://192.168.0.2:8080/aks-mkaqjcyj/cameraMonitoring/intrusionDetection
VA_ALARM_ENDPOINTS_HELMET=http://192.168.0.2:8080/aks-mkaqjcyj/cameraMonitoring/safetyHelmetDetection
VA_ALARM_ENDPOINTS_OVERCROWD=http://192.168.0.2:8080/aks-mkaqjcyj/cameraMonitoring/crowdGathering
VA_ALARM_ENDPOINTS_SMOKEFIRE=http://192.168.0.2:8080/aks-mkaqjcyj/cameraMonitoring/smokeFireDetection
VA_ALARM_TIMEOUT=10
VA_ALARM_RETRY_COUNT=3

# ==================== 流处理配置 ====================
VA_STREAM_FPS=25
VA_STREAM_SKIP_FRAMES=0
VA_STREAM_MAX_RECONNECT=5
VA_STREAM_PRE_BUFFER_SECONDS=3
VA_STREAM_POST_RECORD_SECONDS=3

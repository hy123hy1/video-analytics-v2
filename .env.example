# Copy this file to .env and adjust values for each deployment environment.
# V2 will prefer loading .env from the same directory as the executable.

# ==================== Server ====================
VA_SERVER_HOST=0.0.0.0
VA_SERVER_PORT=5005
VA_SERVER_DEBUG=false
VA_SERVER_RTSP_PUSH_HOST=your-rtsp-host
VA_SERVER_LOG_LEVEL=INFO
VA_SERVER_LOG_FILE=logs/video_analytics.log

# ==================== Model ====================
# backend: ultralytics / tensorrt / onnx / torch
VA_MODEL_BACKEND=ultralytics
VA_MODEL_PERSON_MODEL_PATH=models/yolov8n.pt
VA_MODEL_HELMET_MODEL_PATH=models/safehat.pt
VA_MODEL_SMOKEFIRE_MODEL_PATH=models/smokefire.pt
VA_MODEL_INPUT_SIZE=640,640
VA_MODEL_CONFIDENCE=0.4
VA_MODEL_IOU=0.45
VA_MODEL_DEVICE_ID=0
VA_MODEL_FP16=false

# ==================== Detection ====================
VA_DETECTION_INTRUSION_MIN_FRAMES=25
VA_DETECTION_INTRUSION_COOLDOWN=60.0
VA_DETECTION_INTRUSION_CONFIDENCE=0.5
VA_DETECTION_HELMET_MIN_FRAMES=25
VA_DETECTION_HELMET_COOLDOWN=60.0
VA_DETECTION_HELMET_CONFIDENCE=0.4
VA_DETECTION_HELMET_CROP_PADDING=0.2
VA_DETECTION_OVERCROWD_MAX_PEOPLE=15
VA_DETECTION_OVERCROWD_DURATION=2.0
VA_DETECTION_OVERCROWD_COOLDOWN=60.0
VA_DETECTION_OVERCROWD_CONFIDENCE=0.4
VA_DETECTION_FIRE_MIN_FRAMES=25
VA_DETECTION_FIRE_COOLDOWN=60.0
VA_DETECTION_FIRE_CONFIDENCE=0.4

# ==================== Storage ====================
# type: minio / local
VA_STORAGE_TYPE=minio
VA_STORAGE_ENDPOINT=your-minio-host:9000
VA_STORAGE_ACCESS_KEY=your-access-key
VA_STORAGE_SECRET_KEY=your-secret-key
VA_STORAGE_BUCKET_NAME=yolo
VA_STORAGE_PUBLIC_URL=your-minio-host:9000
VA_STORAGE_SECURE=false
VA_STORAGE_LOCAL_PATH=./output

# ==================== Alarm ====================
# type: http / async / console
VA_ALARM_TYPE=http
VA_ALARM_ENDPOINTS=
VA_ALARM_ENDPOINTS_INTRUSION=http://your-server:8080/api/intrusion
VA_ALARM_ENDPOINTS_HELMET=http://your-server:8080/api/helmet
VA_ALARM_ENDPOINTS_OVERCROWD=http://your-server:8080/api/overcrowd
VA_ALARM_ENDPOINTS_SMOKEFIRE=http://your-server:8080/api/smokefire
VA_ALARM_TIMEOUT=10
VA_ALARM_RETRY_COUNT=3

# ==================== Stream ====================
VA_STREAM_FPS=25
VA_STREAM_SKIP_FRAMES=0
VA_STREAM_MAX_RECONNECT=5
VA_STREAM_RECONNECT_INTERVAL=2.0
VA_STREAM_PRE_BUFFER_SECONDS=3
VA_STREAM_POST_RECORD_SECONDS=3
VA_STREAM_ENABLE_DISPLAY=false
